# 3. בדיקת קניית מטבע (Buy Asset) - נתיב מוגן הדורש את הטוקן
POST http://localhost:5001/api/crypto/buy
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "coinId": "bitcoin",
  "symbol": "btc",
  "name": "Bitcoin",
  "quantity": 0.5,
  "purchasePrice": 65000
}